# ================================================================
# OpenClaw Production Environment Variables
# ================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#   nano .env
#
# IMPORTANT: .env must NEVER be committed to git.
# ================================================================

# --- Anthropic API Key (MOST IMPORTANT) ---
# Get from: https://console.anthropic.com/settings/keys
# Format: sk-ant-api03-XXXXXXXXXXXX
# This key does NOT expire. This is the recommended auth method.
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# --- n8n Host ---
# Your VPS domain pointing to this server (must have valid SSL)
N8N_HOST=n8n.yourdomain.com

# --- n8n UI Auth ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# --- PostgreSQL ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# --- Telegram Bot Token ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=7123456789:AAH_your-token-string-here